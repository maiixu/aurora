{
  "name": "aurora",
  "version": "0.1.0",
  "description": "Voice-to-text injection for macOS",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "install-app": "codesign --deep --force --sign - release/mac-arm64/Aurora.app && cp -R release/mac-arm64/Aurora.app /Applications/",
    "build:electron": "tsc && vite build",
    "preview": "electron dist/main/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-sagemaker-runtime": "^3.1014.0",
    "@aws-sdk/client-transcribe-streaming": "^3.1014.0",
    "electron-store": "^10.0.0",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}
